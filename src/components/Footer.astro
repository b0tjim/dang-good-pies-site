---
import pages from "../../data/pages.json";
import site from "../../data/site.json";

const footerPages = pages
  .filter((p) => p.showInFooter)
  .sort((a, b) => a.order - b.order);

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div>
      <p class="site-footer__brand">{site.businessName}</p>
      <p class="site-footer__muted">{site.location}</p>
      <p class="site-footer__muted">
        Questions? <a href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a>
      </p>
    </div>
    <nav aria-label="Legal">
      <ul class="site-footer__legal">
        {
          footerPages.map((page) => (
            <li>
              <a href={page.path}>{page.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
  <div class="container">
    <p class="site-footer__copyright">
      &copy; {year} {site.businessName}. This is a small home-based cottage food operation.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-bg-alt);
    border-top: 1px solid var(--color-border);
    padding: var(--space-lg) 0 var(--space-md);
    margin-top: var(--space-xl);
  }

  .site-footer__inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--space-lg);
    margin-bottom: var(--space-md);
  }

  .site-footer__brand {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 700;
    margin: 0 0 var(--space-xs);
  }

  .site-footer__muted {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin: 0 0 var(--space-xs);
  }

  .site-footer__legal {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    margin: 0;
    padding: 0;
  }

  .site-footer__copyright {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-sm);
    margin: 0;
  }
</style>
